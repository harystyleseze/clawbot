# ============================================
# ClawBot Configuration
# ============================================

# --- Telegram (REQUIRED) ---
# Get from @BotFather on Telegram: /newbot
BOT_TOKEN=your_bot_token_from_botfather
# Your Telegram user ID (get from @userinfobot). Comma-separated for multiple admins.
ADMIN_IDS=123456789

# --- AI Providers (at least one REQUIRED) ---
# Priority: Groq → Grok → LibertAI → Anthropic → Ollama
# Groq: FREE, sub-second responses. Sign up at https://console.groq.com
GROQ_API_KEY=
# xAI Grok: $25 free credits. Sign up at https://x.ai/api
GROK_API_KEY=
# LibertAI: $20 free hackathon credits (decentralized AI — sponsor integration)
LIBERTAI_API_KEY=
# Anthropic Claude: Paid premium fallback
ANTHROPIC_API_KEY=
# Ollama: Free local fallback (slow on CPU). Only if running ollama serve locally
OLLAMA_URL=
OLLAMA_MODEL=qwen2.5:1.5b
# ChainGPT: Blockchain-specific queries only (sponsor integration)
CHAINGPT_API_KEY=

# --- TON Blockchain ---
# TON Center API key: message @tonapibot on Telegram
TON_API_KEY=
# Your TON wallet address for receiving deposits
TON_WALLET_ADDRESS=
# true = testnet (dev), false = mainnet (production/demo)
TON_TESTNET=true
# Deposit amount in TON
DEPOSIT_AMOUNT_TON=2.0

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///data/clawbot.db

# --- Rate Limits / Permissions ---
MAX_BOOKINGS_PER_USER=3
MAX_PARTY_SIZE=20
BOOKING_WINDOW_DAYS=30
# Set true for production — removes "Skip Deposit" button
REQUIRE_DEPOSIT=false

# --- Optional ---
REDIS_DSN=redis://localhost:6379/0
LOG_LEVEL=DEBUG
